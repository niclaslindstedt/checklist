{
  "expo": {
    "name": "checklist",
    "slug": "checklist",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "checklist",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1115"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 28,
            "usesCleartextTraffic": true
          }
        }
      ],
      "./plugins/withWebroot"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "se.niclaslindstedt.checklist",
      "entitlements": {
        "com.apple.developer.ubiquity-kvstore-identifier": "$(TeamIdentifierPrefix)se.niclaslindstedt.checklist"
      },
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true,
          "NSAllowsArbitraryLoadsInWebContent": true,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": false
            }
          }
        }
      }
    },
    "android": {
      "package": "se.niclaslindstedt.checklist",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1f2933"
      }
    },
    "extra": {
      "eas": {
        "projectId": "ba72b2a4-c8ba-456a-96fb-9107ccb35893"
      }
    }
  }
}
