{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true
  },
  "include": ["index.js", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "webroot", "ios", "android"]
}
