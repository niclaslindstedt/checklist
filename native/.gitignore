node_modules/
.expo/
dist/

# The embedded web build, produced by `npm run build:web` from the web app in
# `../src`. Generated, never committed — but note it MUST exist before
# `expo prebuild` or the wrapper ships with no app inside it. CI regenerates
# it; see `.github/workflows/native-build.yml`.
webroot/

# Generated by `expo prebuild`. Regenerated from `app.json` + the config
# plugins in `plugins/`, so it is not the source of truth for anything.
ios/
android/

*.log
