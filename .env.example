# Example build-time environment for checklist. Copy to `.env` (which is
# git-ignored) and fill in as needed. All vars are optional — the app
# builds and runs without any of them.

# URL the header menu's "Donate" entry links to. Leave unset or blank to
# hide the entry entirely.
# VITE_DONATE_URL=https://github.com/sponsors/niclaslindstedt

# Dropbox app key (PKCE public client). Unset hides the Dropbox storage
# backend in Settings → Storage. Register an app at
# https://www.dropbox.com/developers/apps (scoped access, "App folder").
# VITE_DROPBOX_APP_KEY=

# Google OAuth client id (GIS token client). Unset hides the Google Drive
# storage backend in Settings → Storage. Create an OAuth client id in the
# Google Cloud console with the Drive API enabled.
# VITE_GOOGLE_CLIENT_ID=
